# Copy this to .env.local for local development with `vercel dev`
# Set these in Vercel Dashboard → Project Settings → Environment Variables

# ── Vercel KV (Redis) ─────────────────────────────────────────────────────────
# These are auto-populated when you connect a Vercel KV store to your project.
# Go to: Vercel Dashboard → Storage → Create KV → Link to project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ── Admin Secret ──────────────────────────────────────────────────────────────
# Set a strong random string. This is the password for /admin
# Generate one: openssl rand -hex 32
ADMIN_SECRET=JoyStick@221125