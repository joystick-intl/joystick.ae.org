{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/team",    "dest": "/public/team.html" },
    { "src": "/admin",   "dest": "/public/admin.html" },
    { "src": "/",        "dest": "/public/index.html" },
    { "src": "/(.*)",    "dest": "/public/$1" }
  ]
}